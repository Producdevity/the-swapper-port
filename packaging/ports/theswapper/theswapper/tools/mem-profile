#!/bin/sh
set -eu

pid="$1"
out_dir="$2"
interval="${3:-1}"

mkdir -p "$out_dir"

summary_file="$out_dir/summary.csv"
maps_file="$out_dir/maps.tsv"
snapshots_dir="$out_dir/snapshots"

printf 'timestamp,elapsed_s,pid,vmsize_kb,vmrss_kb,vmdata_kb,threads,rss_kb,pss_kb,anon_kb,file_kb,shmem_kb,swap_kb,mem_available_kb,swap_free_kb,gpu_load,gpu_mem_pages,gpu_freq_hz,cpu_freq_hz,cpu_temp_millic,gpu_temp_millic,load1,proc_cpu_pct\n' > "$summary_file"
printf 'timestamp\telapsed_s\tcategory\trss_kb\tpss_kb\tprivate_clean_kb\tprivate_dirty_kb\tshared_clean_kb\tshared_dirty_kb\tswap_kb\n' > "$maps_file"
mkdir -p "$snapshots_dir"

start_time="$(date +%s)"
clock_ticks="$(getconf CLK_TCK 2>/dev/null || printf '100\n')"
sample=0
last_snapshot_rss=0
last_cpu_ticks=""
last_cpu_time=""

status_value() {
  key="$1"
  [ -r "/proc/$pid/status" ] || {
    printf '0\n'
    return 0
  }
  awk -v key="$key" '$1 == key ":" { print $2; found = 1; exit } END { if (!found) print 0 }' "/proc/$pid/status" 2>/dev/null || printf '0\n'
}

meminfo_value() {
  key="$1"
  awk -v key="$key" '$1 == key ":" { print $2; found = 1; exit } END { if (!found) print 0 }' /proc/meminfo 2>/dev/null || printf '0\n'
}

gpu_load() {
  for load_file in /sys/class/devfreq/*gpu*/load /sys/class/devfreq/*mali*/load; do
    [ -r "$load_file" ] || continue
    tr -d '\n' < "$load_file"
    return 0
  done

  if [ -r /sys/kernel/debug/sunxi_gpu/dump ]; then
    awk -F '[:%;]' '
      /Utilisation from last show/ {
        gsub(/[[:space:]]/, "", $2)
        print $2
        found = 1
        exit
      }
      END {
        if (!found) print "NA"
      }
    ' /sys/kernel/debug/sunxi_gpu/dump
    return 0
  fi

  printf 'NA'
}

gpu_mem_pages() {
  for memory_file in /sys/kernel/debug/mali*/gpu_memory; do
    [ -r "$memory_file" ] || continue
    awk 'NR == 1 { print $2; found = 1; exit } END { if (!found) print "NA" }' "$memory_file"
    return 0
  done
  printf 'NA'
}

gpu_freq_hz() {
  for freq_file in \
    /sys/class/devfreq/*gpu*/cur_freq \
    /sys/class/devfreq/*mali*/cur_freq \
    /sys/devices/platform/gpu/devfreq/gpu/cur_freq \
    /sys/kernel/debug/clk/gpu0/clk_rate; do
    [ -r "$freq_file" ] || continue
    tr -d '\n' < "$freq_file"
    return 0
  done
  printf 'NA'
}

cpu_freq_hz() {
  for freq_file in \
    /sys/devices/system/cpu/cpufreq/policy0/scaling_cur_freq \
    /sys/devices/system/cpu/cpu0/cpufreq/scaling_cur_freq; do
    [ -r "$freq_file" ] || continue
    awk '{ print $1 * 1000 }' "$freq_file"
    return 0
  done
  printf 'NA'
}

thermal_temp_millic() {
  type_pattern="$1"

  for temp_file in /sys/class/thermal/thermal_zone*/temp; do
    [ -r "$temp_file" ] || continue
    type_file="${temp_file%/temp}/type"
    zone_type="$(cat "$type_file" 2>/dev/null || true)"
    case "$zone_type" in
      *"$type_pattern"*)
        tr -d '\n' < "$temp_file"
        return 0
        ;;
    esac
  done
  printf 'NA'
}

load1() {
  awk '{ print $1 }' /proc/loadavg 2>/dev/null || printf 'NA\n'
}

process_cpu_ticks() {
  [ -r "/proc/$pid/stat" ] || {
    printf '0\n'
    return 0
  }
  awk '{ print $14 + $15 }' "/proc/$pid/stat" 2>/dev/null || printf '0\n'
}

process_cpu_pct() {
  now="$1"
  ticks="$2"

  if [ -z "$last_cpu_ticks" ] || [ -z "$last_cpu_time" ]; then
    printf '0.0\n'
    return 0
  fi

  elapsed_ticks=$((ticks - last_cpu_ticks))
  elapsed_time=$((now - last_cpu_time))
  if [ "$elapsed_ticks" -lt 0 ] || [ "$elapsed_time" -le 0 ] || [ "$clock_ticks" -le 0 ]; then
    printf '0.0\n'
    return 0
  fi

  awk -v ticks="$elapsed_ticks" -v hz="$clock_ticks" -v seconds="$elapsed_time" \
    'BEGIN { printf "%.1f\n", (ticks * 100.0) / (hz * seconds) }'
}

append_rollup() {
  [ -r "/proc/$pid/smaps_rollup" ] || {
    printf '0,0,0,0,0,0\n'
    return 0
  }

  awk '
    $1 == "Rss:" { rss = $2 }
    $1 == "Pss:" { pss = $2 }
    $1 == "Anonymous:" { anon = $2 }
    $1 == "Swap:" { swap = $2 }
    END {
      if (rss == "") rss = 0
      if (pss == "") pss = 0
      if (anon == "") anon = 0
      if (swap == "") swap = 0
      file = rss - anon
      if (file < 0) file = 0
      print rss "," pss "," anon "," file ",0," swap
    }
  ' "/proc/$pid/smaps_rollup" 2>/dev/null || printf '0,0,0,0,0,0\n'
}

append_maps() {
  timestamp="$1"
  elapsed="$2"

  awk -v timestamp="$timestamp" -v elapsed="$elapsed" '
    function category(path) {
      if (path == "") return "[anon]"
      if (path ~ /^\[/) return path
      if (path ~ /\/gamedata\/data\/textures\//) return "gamedata:data/textures"
      if (path ~ /\/gamedata\/data\/audio\//) return "gamedata:data/audio"
      if (path ~ /\/gamedata\/data\/shaders\//) return "gamedata:data/shaders"
      if (path ~ /\/gamedata\/data\/#sp#levels_sp\//) return "gamedata:data/levels"
      if (path ~ /\/gamedata\/data\//) return "gamedata:data/other"
      if (path ~ /\/gamedata\//) return "gamedata:root"
      if (path ~ /\/ports\/theswapper\/libs/) return "port:libs"
      if (path ~ /\/mono\//) return "mono-runtime"
      if (path ~ /^\/usr\// || path ~ /^\/lib/ || path ~ /\/lib64\//) return "system-libs"
      if (path ~ /^\/dev\//) return "device"
      return "other-files"
    }

    /^[0-9a-fA-F]+-[0-9a-fA-F]+/ {
      path = ""
      if (NF >= 6) {
        path = $6
        for (i = 7; i <= NF; i++) path = path " " $i
      }
      current = category(path)
      seen[current] = 1
      next
    }

    $1 == "Rss:" { rss[current] += $2; next }
    $1 == "Pss:" { pss[current] += $2; next }
    $1 == "Private_Clean:" { private_clean[current] += $2; next }
    $1 == "Private_Dirty:" { private_dirty[current] += $2; next }
    $1 == "Shared_Clean:" { shared_clean[current] += $2; next }
    $1 == "Shared_Dirty:" { shared_dirty[current] += $2; next }
    $1 == "Swap:" { swap[current] += $2; next }

    END {
      for (key in seen) {
        print timestamp "\t" elapsed "\t" key "\t" rss[key] + 0 "\t" pss[key] + 0 "\t" private_clean[key] + 0 "\t" private_dirty[key] + 0 "\t" shared_clean[key] + 0 "\t" shared_dirty[key] + 0 "\t" swap[key] + 0
      }
    }
  ' "/proc/$pid/smaps" >> "$maps_file" 2>/dev/null || true
}

write_snapshot() {
  timestamp="$1"
  elapsed="$2"
  vmrss="$3"
  reason="$4"
  snapshot_dir="$snapshots_dir/${elapsed}s-${vmrss}kb-${reason}"

  mkdir -p "$snapshot_dir"
  cp "/proc/$pid/status" "$snapshot_dir/status" 2>/dev/null || true
  cp "/proc/$pid/statm" "$snapshot_dir/statm" 2>/dev/null || true
  cp "/proc/$pid/maps" "$snapshot_dir/maps" 2>/dev/null || true
  cp "/proc/$pid/smaps_rollup" "$snapshot_dir/smaps_rollup" 2>/dev/null || true
  cp "/proc/$pid/smaps" "$snapshot_dir/smaps" 2>/dev/null || true
  cp /proc/meminfo "$snapshot_dir/meminfo" 2>/dev/null || true
  ps w > "$snapshot_dir/ps.txt" 2>/dev/null || true
  dmesg | tail -n 80 > "$snapshot_dir/dmesg-tail.txt" 2>/dev/null || true
  printf 'timestamp=%s\nelapsed_s=%s\nvmrss_kb=%s\nreason=%s\n' "$timestamp" "$elapsed" "$vmrss" "$reason" > "$snapshot_dir/meta.txt"
}

while [ -d "/proc/$pid" ]; do
  timestamp="$(date +%s)"
  elapsed=$((timestamp - start_time))

  vmsize="$(status_value VmSize)"
  vmrss="$(status_value VmRSS)"
  vmdata="$(status_value VmData)"
  threads="$(status_value Threads)"
  rollup="$(append_rollup)"
  old_ifs="$IFS"
  IFS=,
  set -- $rollup
  IFS="$old_ifs"
  rss="${1:-0}"
  pss="${2:-0}"
  anon="${3:-0}"
  file="${4:-0}"
  shmem="${5:-0}"
  swap="${6:-0}"
  mem_available="$(meminfo_value MemAvailable)"
  swap_free="$(meminfo_value SwapFree)"
  gpu="$(gpu_load)"
  gpu_pages="$(gpu_mem_pages)"
  gpu_freq="$(gpu_freq_hz)"
  cpu_freq="$(cpu_freq_hz)"
  cpu_temp="$(thermal_temp_millic cpu)"
  gpu_temp="$(thermal_temp_millic gpu)"
  load_average="$(load1)"
  cpu_ticks="$(process_cpu_ticks)"
  cpu_pct="$(process_cpu_pct "$timestamp" "$cpu_ticks")"

  printf '%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s,%s\n' \
    "$timestamp" "$elapsed" "$pid" "$vmsize" "$vmrss" "$vmdata" "$threads" \
    "$rss" "$pss" "$anon" "$file" "$shmem" "$swap" "$mem_available" "$swap_free" "$gpu" \
    "$gpu_pages" "$gpu_freq" "$cpu_freq" "$cpu_temp" "$gpu_temp" "$load_average" "$cpu_pct" \
    >> "$summary_file"

  last_cpu_ticks="$cpu_ticks"
  last_cpu_time="$timestamp"

  if [ $((sample % 5)) -eq 0 ]; then
    append_maps "$timestamp" "$elapsed"
  fi

  if [ "$vmrss" -gt 262144 ] && [ $((vmrss - last_snapshot_rss)) -ge 65536 ]; then
    write_snapshot "$timestamp" "$elapsed" "$vmrss" "rss"
    last_snapshot_rss="$vmrss"
  elif [ "$mem_available" -gt 0 ] && [ "$mem_available" -lt 98304 ]; then
    write_snapshot "$timestamp" "$elapsed" "$vmrss" "lowmem"
  fi

  sample=$((sample + 1))
  sleep "$interval"
done
